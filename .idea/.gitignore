target/
*.class
*.jar
*.war
*.ear

# Maven 本地缓存（自己机器上的依赖包，不需要传）
.m2/

# ============ Vue 前端 ============
# 依赖安装目录
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

