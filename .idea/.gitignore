application-dev.yml
application-prod.yml
application-local.yml
application-*.yml

# 环境变量文件
.env
.env.local
.env.*.local

# 密钥文件
*.pem
*.key
*.crt

# ============ 日志文件 ============
logs/
*.log

# ============ 临时文件 ============
tmp/
temp/
*.tmp