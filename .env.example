# 使用方式：复制此文件为 .env，填入真实值
# 注意：.env 文件已在 .gitignore 中，不会被提交到 Git

# DeepSeek API Key（必填）
# 从 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=your-api-key-here

# 数据库密码（选填，默认 123456）
DB_PASSWORD=123456

# Druid 控制台密码（选填，默认 123456）
DRUID_PASSWORD=123456

# JWT Token 密钥（选填）
TOKEN_SECRET=abcdefghijklmnopqrstuvwxyz
