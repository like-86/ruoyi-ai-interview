<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.interview.mapper.InterviewAnswerMapper">
    
    <resultMap type="InterviewAnswer" id="InterviewAnswerResult">
        <result property="id"    column="id"    />
        <result property="questionId"    column="question_id"    />
        <result property="content"    column="content"    />
        <result property="audioUrl"    column="audio_url"    />
        <result property="duration"    column="duration"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectInterviewAnswerVo">
        select id, question_id, content, audio_url, duration, create_time, update_time from interview_answer
    </sql>

    <select id="selectInterviewAnswerList" parameterType="InterviewAnswer" resultMap="InterviewAnswerResult">
        <include refid="selectInterviewAnswerVo"/>
        <where>  
            <if test="questionId != null "> and question_id = #{questionId}</if>
            <if test="content != null  and content != ''"> and content = #{content}</if>
            <if test="audioUrl != null  and audioUrl != ''"> and audio_url = #{audioUrl}</if>
            <if test="duration != null "> and duration = #{duration}</if>
        </where>
    </select>
    
    <select id="selectInterviewAnswerById" parameterType="Long" resultMap="InterviewAnswerResult">
        <include refid="selectInterviewAnswerVo"/>
        where id = #{id}
    </select>
    <select id="selectInterviewAnswerByQuestionId" resultType="com.ruoyi.interview.domain.InterviewAnswer">
        select * from interview_answer where question_id in
        <foreach collection="list" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </select>

    <insert id="insertInterviewAnswer" parameterType="InterviewAnswer" useGeneratedKeys="true" keyProperty="id">
        insert into interview_answer
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="questionId != null">question_id,</if>
            <if test="content != null">content,</if>
            <if test="audioUrl != null">audio_url,</if>
            <if test="duration != null">duration,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="questionId != null">#{questionId},</if>
            <if test="content != null">#{content},</if>
            <if test="audioUrl != null">#{audioUrl},</if>
            <if test="duration != null">#{duration},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateInterviewAnswer" parameterType="InterviewAnswer">
        update interview_answer
        <trim prefix="SET" suffixOverrides=",">
            <if test="questionId != null">question_id = #{questionId},</if>
            <if test="content != null">content = #{content},</if>
            <if test="audioUrl != null">audio_url = #{audioUrl},</if>
            <if test="duration != null">duration = #{duration},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteInterviewAnswerById" parameterType="Long">
        delete from interview_answer where id = #{id}
    </delete>

    <delete id="deleteInterviewAnswerByIds" parameterType="String">
        delete from interview_answer where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>